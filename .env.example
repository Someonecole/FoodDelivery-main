# MongoDB Atlas connection string. Keep this server-side only.
# Replace <USERNAME>, <PASSWORD>, and cluster host with your Atlas values.
MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@cluster0.xyxm4vf.mongodb.net/fooddelivery?retryWrites=true&w=majority&appName=Cluster0

# Database name used by the app.
MONGODB_DB=fooddelivery

# Required in production. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret
